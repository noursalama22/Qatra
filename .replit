modules = ["nodejs-20"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
integrations = ["javascript_log_in_with_replit:2.0.0", "javascript_database:1.0.0"]
stack = "BEST_EFFORT_FALLBACK"

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Qatra"

[[workflows.workflow]]
name = "Start Qatra"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000
